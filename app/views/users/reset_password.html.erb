<% content_for :title, "Reset password" %>

<main class="page">
  <section class="hero-banner hero-banner--ticket">
    <div>
      <div class="hero-banner__eyebrow">Admin workspace</div>
      <h1>Reset password</h1>
      <p class="page-subtitle">Set a new password for this account directly from the admin console.</p>

      <div class="hero-banner__meta">
        <span class="mini-ticket__domain"><%= @user.email %></span>
        <span class="status-pill status-pill--<%= @user.role == "admin" ? "resolved" : "open" %>"><%= @user.display_role %></span>
      </div>
    </div>

    <div class="hero-banner__actions hero-banner__actions--stacked">
      <div class="ticket-show__stats">
        <div class="ticket-show__stat">
          <span>User</span>
          <strong><%= @user.name %></strong>
        </div>
        <div class="ticket-show__stat">
          <span>Role</span>
          <strong><%= @user.display_role %></strong>
        </div>
      </div>

      <div class="page-header__actions">
        <%= link_to "All users", users_path, class: "button button--secondary" %>
        <%= link_to "Edit user", edit_user_path(@user), class: "button button--secondary" %>
      </div>
    </div>
  </section>

  <section class="surface ticket-section-gap">
    <%= form_with model: @user, url: reset_password_user_path(@user), method: :patch, class: "ticket-form" do |form| %>
      <% if @user.errors.any? %>
        <div class="flash flash--alert">
          <strong><%= pluralize(@user.errors.count, "error") %> prevented this password reset:</strong>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-shell">
        <section class="form-section">
          <div class="form-section__header">
            <div class="detail-card__eyebrow">Credentials</div>
            <h2>New password</h2>
            <p class="detail-muted">Use this flow when the admin needs to reset the user's credentials directly.</p>
          </div>

          <div class="form-grid">
            <div class="field">
              <%= form.label :password %>
              <%= form.password_field :password, required: true, autocomplete: "new-password" %>
            </div>

            <div class="field">
              <%= form.label :password_confirmation %>
              <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
            </div>
          </div>
        </section>
      </div>

      <div class="form-actions">
        <%= form.submit "Reset password", class: "button" %>
        <%= link_to "Cancel", users_path, class: "button button--secondary" %>
      </div>
    <% end %>
  </section>

  <section class="detail-grid detail-grid--stacked ticket-section-gap">
    <%= render "audit_events", user_events: @user_events %>
  </section>
</main>
