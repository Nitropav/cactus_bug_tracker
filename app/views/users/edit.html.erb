<% content_for :title, "Edit user" %>

<main class="page">
  <section class="hero-banner hero-banner--ticket">
    <div>
      <div class="hero-banner__eyebrow">Admin workspace</div>
      <h1>Edit user</h1>
      <p class="page-subtitle">Update account identity and role without changing the password.</p>

      <div class="hero-banner__meta">
        <span class="mini-ticket__domain"><%= @user.email %></span>
        <span class="status-pill status-pill--<%= @user.role == "admin" ? "resolved" : "open" %>"><%= @user.display_role %></span>
      </div>
    </div>

    <div class="hero-banner__actions hero-banner__actions--stacked">
      <div class="ticket-show__stats">
        <div class="ticket-show__stat">
          <span>Created</span>
          <strong><%= @user.created_at.strftime("%Y-%m-%d") %></strong>
        </div>
        <div class="ticket-show__stat">
          <span>Last seen</span>
          <strong><%= @user.last_seen_at ? "#{time_ago_in_words(@user.last_seen_at)} ago" : "Never" %></strong>
        </div>
      </div>

      <div class="page-header__actions">
        <%= link_to "All users", users_path, class: "button button--secondary" %>
      </div>
    </div>
  </section>

  <section class="surface ticket-section-gap">
    <%= render "form", user: @user, submit_label: "Save changes", include_password_fields: false %>
  </section>

  <section class="detail-grid detail-grid--stacked ticket-section-gap">
    <%= render "audit_events", user_events: @user_events %>
  </section>
</main>
