<% content_for :title, @ticket.title %>

<main class="page">
  <section class="hero-banner hero-banner--ticket">
    <div>
      <div class="hero-banner__eyebrow">Ticket <%= "BT-#{@ticket.id.to_s.rjust(4, '0')}" %></div>
      <h1><%= @ticket.title %></h1>
      <p class="page-subtitle"><%= @ticket.summary.presence || "No summary has been added yet." %></p>

      <div class="hero-banner__meta">
        <span class="status-pill status-pill--<%= @ticket.status %>"><%= @ticket.display_status %></span>
        <span class="severity-pill severity-pill--<%= @ticket.severity %>"><%= @ticket.display_severity %></span>
        <span class="mini-ticket__domain"><%= @ticket.domain.humanize %></span>
        <span class="mini-ticket__domain">External: <%= @ticket.external_reference.presence || "None" %></span>
      </div>
    </div>

    <div class="hero-banner__actions hero-banner__actions--stacked">
      <div class="ticket-show__stats">
        <div class="ticket-show__stat">
          <span>Reporter</span>
          <strong><%= @ticket.reported_by.name %></strong>
        </div>
        <div class="ticket-show__stat">
          <span>Assignee</span>
          <strong><%= @ticket.assigned_to&.name || "Unassigned" %></strong>
        </div>
        <div class="ticket-show__stat">
          <span>Updated</span>
          <strong><%= time_ago_in_words(@ticket.updated_at) %> ago</strong>
        </div>
      </div>

      <div class="page-header__actions">
        <%= link_to "All tickets", tickets_path, class: "button button--secondary" %>
        <% if @ticket_policy.update? %>
          <%= link_to "Edit ticket", edit_ticket_path(@ticket), class: "button" %>
        <% end %>
        <% if @ticket_policy.destroy? %>
          <%= button_to "Delete ticket", ticket_path(@ticket), method: :delete, form: { data: { turbo_confirm: "Delete this ticket?" } }, class: "button button--secondary" %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="detail-grid detail-grid--three-up" style="margin-top: 1rem;">
    <article class="detail-card detail-card--soft">
      <div class="detail-card__eyebrow">Lifecycle</div>
      <h2>Workflow state</h2>
      <dl class="detail-list">
        <dt>Status</dt>
        <dd><span class="status-pill status-pill--<%= @ticket.status %>"><%= @ticket.display_status %></span></dd>
        <dt>Severity</dt>
        <dd><span class="severity-pill severity-pill--<%= @ticket.severity %>"><%= @ticket.display_severity %></span></dd>
        <dt>Domain</dt>
        <dd><%= @ticket.domain.humanize %></dd>
        <dt>External reference</dt>
        <dd><%= @ticket.external_reference.presence || "None" %></dd>
      </dl>
    </article>

    <article class="detail-card detail-card--soft">
      <div class="detail-card__eyebrow">Ownership</div>
      <h2>People</h2>
      <dl class="detail-list">
        <dt>Reported by</dt>
        <dd><%= @ticket.reported_by.name %> (<%= @ticket.reported_by.display_role %>)</dd>
        <dt>Assigned to</dt>
        <dd><%= @ticket.assigned_to ? "#{@ticket.assigned_to.name} (#{@ticket.assigned_to.display_role})" : "Unassigned" %></dd>
        <dt>Created</dt>
        <dd><%= @ticket.created_at.strftime("%Y-%m-%d %H:%M") %></dd>
        <dt>Updated</dt>
        <dd><%= @ticket.updated_at.strftime("%Y-%m-%d %H:%M") %></dd>
      </dl>
    </article>

    <article class="detail-card detail-card--soft">
      <div class="detail-card__eyebrow">Gate readiness</div>
      <h2>Completion state</h2>
      <div class="ticket-health">
        <div class="ticket-health__row">
          <span class="gate-state <%= @ticket.gate_one_complete? ? "gate-state--complete" : "gate-state--pending" %>">Gate 1 <%= @ticket.gate_one_complete? ? "Complete" : "Pending" %></span>
          <span class="detail-muted"><%= @ticket.gate_one.completed_at ? @ticket.gate_one.completed_at.strftime("%Y-%m-%d %H:%M") : "Reporter input still missing" %></span>
        </div>
        <div class="ticket-health__row">
          <span class="gate-state <%= @ticket.gate_two_complete? ? "gate-state--complete" : "gate-state--pending" %>">Gate 2 <%= @ticket.gate_two_complete? ? "Complete" : "Pending" %></span>
          <span class="detail-muted"><%= @ticket.gate_two.completed_at ? @ticket.gate_two.completed_at.strftime("%Y-%m-%d %H:%M") : "Developer resolution still missing" %></span>
        </div>
      </div>
    </article>
  </section>

  <section class="detail-grid detail-grid--stacked ticket-section-gap">
    <%= render "gate_one_form", ticket: @ticket %>
    <%= render "gate_two_form", ticket: @ticket %>
  </section>

  <% if @ticket_policy.view_commits? %>
    <section class="detail-grid detail-grid--stacked ticket-section-gap">
      <%= render "commit_links_section", ticket: @ticket, new_ticket_commit: @new_ticket_commit %>
    </section>
  <% end %>

  <% if current_user.can_review? && @latest_training_example.present? %>
    <section class="detail-grid detail-grid--stacked ticket-section-gap">
      <article class="detail-card detail-card--soft">
        <div class="detail-card__eyebrow">Training pipeline</div>
        <div class="detail-card__header">
          <div>
            <h2>Latest training example</h2>
            <p class="detail-card__description">Resolved tickets generate a draft example that can be reviewed before export.</p>
          </div>
          <div class="detail-card__meta-actions">
            <span class="status-pill status-pill--<%= @latest_training_example.status_pending_review? ? "needs_review" : "resolved" %>"><%= @latest_training_example.display_status %></span>
          </div>
        </div>

        <dl class="detail-list">
          <dt>Generated</dt>
          <dd><%= @latest_training_example.generated_timestamp.strftime("%Y-%m-%d %H:%M") %></dd>
          <dt>Reviewed by</dt>
          <dd><%= @latest_training_example.reviewed_by&.name || "Not reviewed yet" %></dd>
        </dl>

        <div class="ticket-form__actions">
          <%= link_to "Open training example", training_example_path(@latest_training_example), class: "button" %>
          <%= link_to "Training queue", training_examples_path, class: "button button--secondary" %>
        </div>
      </article>
    </section>
  <% end %>

  <section class="detail-grid ticket-section-gap">
    <% if @ticket_policy.comment? %>
      <%= render "comment_form", ticket: @ticket, new_comment: @new_comment %>
    <% end %>
    <%= render "events_list", ticket: @ticket %>
  </section>

  <section id="comments" class="detail-grid detail-grid--stacked ticket-section-gap">
    <%= render "comments_list", ticket: @ticket %>
  </section>
</main>
